---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const today = new Date();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <p class="footer-title">{t('site.title')}</p>
      <p class="footer-copy">{t('site.footer_copy')}</p>
    </div>

    <div class="footer-sections">
      <div class="footer-section">
        <h3 class="footer-section-title">Quick Links</h3>
        <div class="footer-links">
          <a href={translatePath('/')}>Home</a>
          <a href={translatePath('/blog')}>Blog</a>
          <a href={translatePath('/about')}>About</a>
          <a href={translatePath('/privacy')}>Privacy</a>
        </div>
      </div>

      <div class="footer-section">
        <h3 class="footer-section-title">Categories</h3>
        <div class="footer-links">
          <a href={translatePath('/blog?category=AI')}>AI & Machine Learning</a>
          <a href={translatePath('/blog?category=Career')}>Career Development</a>
          <a href={translatePath('/blog?category=Mindset')}>Mindset & Thinking</a>
          <a href={translatePath('/blog?category=Productivity')}>Productivity</a>
        </div>
      </div>

      <div class="footer-section">
        <h3 class="footer-section-title">Connect</h3>
        <div class="social-links">
          <a
            class="icon-link"
            href="mailto:rainiee@gmail.com"
            aria-label="Email"
            title="Email"
          >
            <span class="sr-only">Email</span>
            <svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
              <path
                fill="currentColor"
                d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2zm0 2v.2l8 4.8 8-4.8V7H4zm16 10V9.3l-7.47 4.48a1 1 0 0 1-1.06 0L4 9.3V17h16z"
              />
            </svg>
          </a>
          <a
            class="icon-link"
            href="https://twitter.com/rainee0716"
            target="_blank"
            rel="noreferrer"
            aria-label="Twitter"
            title="Twitter"
          >
            <span class="sr-only">Twitter</span>
            <svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
              <path
                fill="currentColor"
                d="M19.5 7.5c.01.14.01.29.01.44 0 4.5-3.43 9.7-9.7 9.7-1.93 0-3.72-.56-5.23-1.52.27.03.54.04.82.04 1.6 0 3.07-.55 4.25-1.46a3.42 3.42 0 0 1-3.19-2.38c.2.03.4.05.62.05.3 0 .6-.04.88-.12a3.42 3.42 0 0 1-2.74-3.35v-.04c.46.26.99.42 1.56.44a3.42 3.42 0 0 1-1.06-4.56 9.72 9.72 0 0 0 7.06 3.58 3.86 3.86 0 0 1-.09-.78 3.42 3.42 0 0 1 5.91-2.34 6.73 6.73 0 0 0 2.17-.83 3.41 3.41 0 0 1-1.5 1.89 6.78 6.78 0 0 0 1.96-.53 7.35 7.35 0 0 1-1.7 1.77z"
              />
            </svg>
          </a>
          <a
            class="icon-link"
            href="https://github.com/rainiee"
            target="_blank"
            rel="noreferrer"
            aria-label="GitHub"
            title="GitHub"
          >
            <span class="sr-only">GitHub</span>
            <svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
              <path
                fill="currentColor"
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              />
            </svg>
          </a>
          <a
            class="icon-link"
            href="https://linkedin.com/in/rainiee"
            target="_blank"
            rel="noreferrer"
            aria-label="LinkedIn"
            title="LinkedIn"
          >
            <span class="sr-only">LinkedIn</span>
            <svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
              <path
                fill="currentColor"
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="copyright">&copy; {today.getFullYear()} Rainiee. All rights reserved.</p>
    <div class="footer-legal">
      <a href={translatePath('/privacy')}>Privacy Policy</a>
      <span class="separator">•</span>
      <a href="/sitemap.xml">Sitemap</a>
      <span class="separator">•</span>
      <a href="/rss.xml">RSS Feed</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding: 3rem 1.5rem 2rem;
    background: rgba(255, 255, 255, 0.95);
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    width: min(var(--page-max), 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    margin-bottom: 2rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-title {
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0;
    color: rgb(var(--ink));
  }

  .footer-copy {
    margin: 0;
    color: rgb(var(--ink-soft));
    line-height: 1.6;
    max-width: 400px;
  }

  .footer-sections {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .footer-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-section-title {
    font-size: 0.9rem;
    font-weight: 700;
    margin: 0;
    color: rgb(var(--ink));
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a {
    color: rgb(var(--ink-soft));
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s var(--ease-out);
  }

  .footer-links a:hover {
    color: var(--accent-strong);
  }

  .social-links {
    display: flex;
    gap: 0.8rem;
  }

  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: rgb(var(--ink-soft));
    transition: all 0.2s var(--ease-out);
    background: rgba(var(--surface), 0.8);
  }

  .icon-link:hover {
    color: var(--accent-strong);
    background: rgba(var(--accent-strong), 0.1);
    border-color: var(--accent-strong);
    transform: translateY(-2px);
  }

  .footer-bottom {
    width: min(var(--page-max), 100%);
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright {
    margin: 0;
    color: rgb(var(--ink-soft));
    font-size: 0.85rem;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
  }

  .footer-legal a {
    color: rgb(var(--ink-soft));
    text-decoration: none;
    transition: color 0.2s var(--ease-out);
  }

  .footer-legal a:hover {
    color: var(--accent-strong);
  }

  .separator {
    color: rgb(var(--ink-soft));
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }

    .footer-sections {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>