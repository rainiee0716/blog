---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { useTranslatedPath } from '../i18n/utils';
import { ui } from '../i18n/ui';

type Lang = keyof typeof ui;

interface Props {
  currentPost: CollectionEntry<'blog'>;
  maxRelated?: number;
}

const { currentPost, maxRelated = 3 } = Astro.props;

// `currentPost.id` is the rendered URL pathname (e.g. "blog/foo", "en/blog/foo",
// "ja/blog/foo") — set in BlogPost.astro. The collection entries have their own
// id of the form "<lang>/<slug>" (e.g. "zh/ai-workflow"). Derive the current
// language and slug from the URL path so we can build correct translated URLs
// and exclude the current post from the related list.
const urlPath = currentPost.id.replace(/^\//, '').replace(/\.html$/, '').replace(/\/$/, '');
const currentLang: Lang = urlPath.startsWith('en/')
  ? 'en'
  : urlPath.startsWith('ja/')
    ? 'ja'
    : 'zh';
const currentSlug = urlPath.split('/').filter(Boolean).pop() ?? '';
const translatePath = useTranslatedPath(currentLang);

// Get all blog posts and filter to the current language only — the previous
// version showed cross-language posts (e.g. an `en/` post on a `zh/` page),
// whose hrefs also broke because they didn't include the `/blog/` prefix.
const allPosts = (await getCollection('blog')).filter(
  (post) => post.id.startsWith(`${currentLang}/`),
);

// Simple related posts algorithm based on category and title overlap
function getRelatedPosts(currentPost: CollectionEntry<'blog'>, posts: CollectionEntry<'blog'>[], limit: number) {
  const currentCategory = currentPost.data.category;
  const currentTitle = currentPost.data.title.toLowerCase();

  const scored = posts
    .filter((post) => post.id !== `${currentLang}/${currentSlug}`)
    .map((post) => {
      let score = 0;

      if (post.data.category === currentCategory) {
        score += 10;
      }

      const postTitle = post.data.title.toLowerCase();
      const currentWords = currentTitle.split(/\s+/);
      const postWords = postTitle.split(/\s+/);

      const commonWords = currentWords.filter((word) =>
        word.length > 3 && postWords.some((pw) => pw.includes(word) || word.includes(pw)),
      );

      score += commonWords.length * 2;

      return { post, score };
    })
    .filter((item) => item.score > 0)
    .sort((a, b) => b.score - a.score)
    .slice(0, limit);

  return scored.map((item) => item.post);
}

let relatedPosts = getRelatedPosts(currentPost, allPosts, maxRelated);

if (relatedPosts.length === 0) {
  // Fallback: show recent same-language posts if no related posts found
  relatedPosts = allPosts
    .filter((post) => post.id !== `${currentLang}/${currentSlug}`)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, maxRelated);
}
---

{relatedPosts.length > 0 && (
  <aside class="related-posts" aria-labelledby="related-posts-title">
    <h2 id="related-posts-title" class="related-posts-title">
      <svg class="title-icon" viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
        <path
          fill="currentColor"
          d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"
        />
      </svg>
      Related Articles
    </h2>
    <div class="related-posts-grid">
      {relatedPosts.map((post) => {
        const postSlug = post.id.replace(`${currentLang}/`, '');
        const href = translatePath(`/blog/${postSlug}`);
        return (
        <a href={href} class="related-post-card">
          <div class="related-post-content">
            {post.data.category && (
              <span class="related-post-category">{post.data.category}</span>
            )}
            <h3 class="related-post-title">{post.data.title}</h3>
            <p class="related-post-description">{post.data.description}</p>
            <div class="related-post-meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric'
                })}
              </time>
            </div>
          </div>
        </a>
        );
      })}
    </div>
  </aside>
)}

<style>
  .related-posts {
    margin-top: 4rem;
    padding: 2.5rem;
    background: rgba(var(--surface), 0.6);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .related-posts-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: rgb(var(--ink));
    margin-bottom: 2rem;
  }

  .title-icon {
    color: var(--accent-strong);
  }

  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .related-post-card {
    display: block;
    padding: 1.5rem;
    background: rgba(var(--surface), 0.8);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: all 0.3s var(--ease-out);
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  .related-post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--accent-strong);
    transform: scaleY(0);
    transition: transform 0.3s var(--ease-out);
  }

  .related-post-card:hover {
    border-color: var(--accent-strong);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .related-post-card:hover::before {
    transform: scaleY(1);
  }

  .related-post-content {
    position: relative;
    z-index: 1;
  }

  .related-post-category {
    display: inline-block;
    padding: 0.3rem 0.6rem;
    background: rgba(var(--accent-strong), 0.1);
    color: var(--accent-strong);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 4px;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .related-post-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: rgb(var(--ink));
    margin-bottom: 0.75rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-post-description {
    font-size: 0.9rem;
    color: rgb(var(--ink-soft));
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: rgb(var(--ink-soft));
  }

  .related-post-meta time {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  @media (max-width: 720px) {
    .related-posts {
      padding: 1.5rem;
    }

    .related-posts-grid {
      grid-template-columns: 1fr;
    }

    .related-post-card {
      padding: 1.25rem;
    }
  }
</style>