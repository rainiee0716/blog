---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  currentPost: CollectionEntry<'blog'>;
  maxRelated?: number;
}

const { currentPost, maxRelated = 3 } = Astro.props;

// Get all blog posts
const allPosts = await getCollection('blog');

// Simple related posts algorithm based on category and tags
function getRelatedPosts(currentPost: CollectionEntry<'blog'>, allPosts: CollectionEntry<'blog'>[], limit: number) {
  const currentCategory = currentPost.data.category;
  const currentTitle = currentPost.data.title.toLowerCase();

  // Score each post
  const scored = allPosts
    .filter(post => post.id !== currentPost.id) // Exclude current post
    .map(post => {
      let score = 0;

      // Same category gets high score
      if (post.data.category === currentCategory) {
        score += 10;
      }

      // Check for similar words in titles
      const postTitle = post.data.title.toLowerCase();
      const currentWords = currentTitle.split(/\s+/);
      const postWords = postTitle.split(/\s+/);

      const commonWords = currentWords.filter(word =>
        word.length > 3 && postWords.some(pw => pw.includes(word) || word.includes(pw))
      );

      score += commonWords.length * 2;

      return { post, score };
    })
    .filter(item => item.score > 0) // Only include posts with some relevance
    .sort((a, b) => b.score - a.score) // Sort by relevance score
    .slice(0, limit); // Take top N posts

  return scored.map(item => item.post);
}

const relatedPosts = getRelatedPosts(currentPost, allPosts, maxRelated);

if (relatedPosts.length === 0) {
  // Fallback: show recent posts if no related posts found
  const recentPosts = allPosts
    .filter(post => post.id !== currentPost.id)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, maxRelated);

  relatedPosts.push(...recentPosts);
}
---

{relatedPosts.length > 0 && (
  <aside class="related-posts" aria-labelledby="related-posts-title">
    <h2 id="related-posts-title" class="related-posts-title">
      <svg class="title-icon" viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
        <path
          fill="currentColor"
          d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"
        />
      </svg>
      Related Articles
    </h2>
    <div class="related-posts-grid">
      {relatedPosts.map((post) => (
        <a href={`/${post.id}`} class="related-post-card">
          <div class="related-post-content">
            {post.data.category && (
              <span class="related-post-category">{post.data.category}</span>
            )}
            <h3 class="related-post-title">{post.data.title}</h3>
            <p class="related-post-description">{post.data.description}</p>
            <div class="related-post-meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric'
                })}
              </time>
            </div>
          </div>
        </a>
      ))}
    </div>
  </aside>
)}

<style>
  .related-posts {
    margin-top: 4rem;
    padding: 2.5rem;
    background: rgba(var(--surface), 0.6);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .related-posts-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: rgb(var(--ink));
    margin-bottom: 2rem;
  }

  .title-icon {
    color: var(--accent-strong);
  }

  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .related-post-card {
    display: block;
    padding: 1.5rem;
    background: rgba(var(--surface), 0.8);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: all 0.3s var(--ease-out);
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  .related-post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--accent-strong);
    transform: scaleY(0);
    transition: transform 0.3s var(--ease-out);
  }

  .related-post-card:hover {
    border-color: var(--accent-strong);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .related-post-card:hover::before {
    transform: scaleY(1);
  }

  .related-post-content {
    position: relative;
    z-index: 1;
  }

  .related-post-category {
    display: inline-block;
    padding: 0.3rem 0.6rem;
    background: rgba(var(--accent-strong), 0.1);
    color: var(--accent-strong);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 4px;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .related-post-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: rgb(var(--ink));
    margin-bottom: 0.75rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-post-description {
    font-size: 0.9rem;
    color: rgb(var(--ink-soft));
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: rgb(var(--ink-soft));
  }

  .related-post-meta time {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  @media (max-width: 720px) {
    .related-posts {
      padding: 1.5rem;
    }

    .related-posts-grid {
      grid-template-columns: 1fr;
    }

    .related-post-card {
      padding: 1.25rem;
    }
  }
</style>