---
interface Props {
  placeholder?: string;
}

const { placeholder = "Search articles..." } = Astro.props;
---

<div class="search-container" id="search-container">
  <div class="search-box">
    <svg class="search-icon" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
      <path
        fill="currentColor"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
      />
    </svg>
    <input
      type="text"
      id="search-input"
      placeholder={placeholder}
      aria-label="Search articles"
      autocomplete="off"
    />
    <button
      id="search-clear"
      class="search-clear"
      aria-label="Clear search"
      style="display: none;"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
        <path
          fill="currentColor"
          d="M18 6L6 18M6 6l12 12"
          stroke="currentColor"
          stroke-width="2"
        />
      </svg>
    </button>
  </div>
  <div id="search-results" class="search-results" style="display: none;"></div>
</div>

<style>
  .search-container {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .search-box {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(var(--surface), 0.95);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: all 0.2s var(--ease-out);
  }

  .search-box:focus-within {
    border-color: var(--accent-strong);
    box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.1);
  }

  .search-icon {
    color: rgb(var(--ink-soft));
    flex-shrink: 0;
  }

  .search-box input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 0.95rem;
    color: rgb(var(--ink));
    outline: none;
  }

  .search-box input::placeholder {
    color: rgb(var(--ink-soft));
  }

  .search-clear {
    background: transparent;
    border: none;
    color: rgb(var(--ink-soft));
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s var(--ease-out);
  }

  .search-clear:hover {
    background: rgba(var(--accent-strong), 0.1);
    color: var(--accent-strong);
  }

  .search-results {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    right: 0;
    background: rgba(var(--surface), 0.98);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    max-height: 400px;
    overflow-y: auto;
    z-index: 100;
    backdrop-filter: blur(10px);
  }

  .search-results:empty {
    display: none;
  }

  .search-result-item {
    padding: 1rem;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.2s var(--ease-out);
  }

  .search-result-item:last-child {
    border-bottom: none;
  }

  .search-result-item:hover {
    background: rgba(var(--accent-strong), 0.05);
  }

  .search-result-title {
    font-weight: 600;
    color: rgb(var(--ink));
    margin-bottom: 0.25rem;
    font-size: 0.95rem;
  }

  .search-result-description {
    font-size: 0.85rem;
    color: rgb(var(--ink-soft));
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: rgb(var(--ink-soft));
  }

  .search-result-category {
    background: rgba(var(--accent-strong), 0.1);
    color: var(--accent-strong);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .search-result-date {
    color: rgb(var(--ink-soft));
  }

  .search-loading {
    padding: 2rem;
    text-align: center;
    color: rgb(var(--ink-soft));
  }

  .search-empty {
    padding: 2rem;
    text-align: center;
    color: rgb(var(--ink-soft));
  }

  @media (max-width: 720px) {
    .search-results {
      max-height: 300px;
    }

    .search-result-item {
      padding: 0.8rem;
    }
  }
</style>

<script>
  // Simple search functionality using article data
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const searchClear = document.getElementById('search-clear');

  // This would be populated from your blog data
  // For now, it's a placeholder that would be replaced with actual search functionality
  let articles = [];

  // Load articles from a JSON endpoint or inline data
  async function loadArticles() {
    try {
      const response = await fetch('/search-index.json');
      if (response.ok) {
        articles = await response.json();
      }
    } catch (error) {
      console.error('Failed to load search index:', error);
    }
  }

  // Initialize search
  loadArticles();

  searchInput?.addEventListener('input', async (e) => {
    const query = e.target.value.trim();

    if (query.length < 2) {
      searchResults.style.display = 'none';
      searchClear.style.display = 'none';
      return;
    }

    searchClear.style.display = 'flex';
    searchResults.style.display = 'block';
    searchResults.innerHTML = '<div class="search-loading">Searching...</div>';

    // Filter articles based on query
    const results = articles.filter(article => {
      const title = article.title.toLowerCase();
      const description = article.description.toLowerCase();
      const content = article.content?.toLowerCase() || '';
      const q = query.toLowerCase();

      return title.includes(q) || description.includes(q) || content.includes(q);
    }).slice(0, 5); // Limit to 5 results

    if (results.length === 0) {
      searchResults.innerHTML = '<div class="search-empty">No articles found</div>';
      return;
    }

    searchResults.innerHTML = results.map(article => `
      <div class="search-result-item" onclick="window.location.href='${article.url}'">
        <div class="search-result-title">${article.title}</div>
        <div class="search-result-description">${article.description}</div>
        <div class="search-result-meta">
          ${article.category ? `<span class="search-result-category">${article.category}</span>` : ''}
          <span class="search-result-date">${new Date(article.date).toLocaleDateString()}</span>
        </div>
      </div>
    `).join('');
  });

  searchClear?.addEventListener('click', () => {
    searchInput.value = '';
    searchResults.style.display = 'none';
    searchClear.style.display = 'none';
    searchInput.focus();
  });

  // Close search results when clicking outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('#search-container')) {
      searchResults.style.display = 'none';
    }
  });
</script>